# ============================================================
# Glance Fashion Retrieval — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The system runs entirely offline without any of these set —
# the Groq API key is the only optional external dependency.

# ------------------------------------------------------------
# Groq API (optional but recommended for better query parsing)
# Sign up for free at https://console.groq.com/
# Without this key, the system falls back to the rule-based
# query parser, which handles most cases but misses nuanced
# style inferences.
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------
# ChromaDB Persistence Path
# Where the vector store is written to disk.
# Default (used when unset): ./chroma_db relative to repo root
# ------------------------------------------------------------
CHROMA_DB_PATH=./chroma_db

# ------------------------------------------------------------
# Data Paths (optional overrides; defaults in config constants)
# ------------------------------------------------------------
IMAGE_DIR=./data/images
METADATA_PATH=./data/metadata.json
CAPTIONS_FILE=./data/captions.json

# ------------------------------------------------------------
# Dataset Split
# Which Fashionpedia split to download.
#   val_test  → ~2-3 GB, ~8,726 images (default, per assignment spec)
#   train     → ~20 GB, ~45,623 images (richer index, stream with --limit)
# This is only read by download_dataset.py; the indexer uses metadata.json
# regardless of which split it was generated from.
# ------------------------------------------------------------
DATASET_SPLIT=val_test

# ------------------------------------------------------------
# Model Selection (optional overrides; defaults shown below)
# Set USE_LIGHTWEIGHT_VLM=true on CPU-only machines to use
# BLIP base (much smaller) instead of BLIP-2.
# ------------------------------------------------------------
USE_LIGHTWEIGHT_VLM=false
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai
TEXT_EMBED_MODEL=BAAI/bge-small-en-v1.5
VLM_MODEL_NAME=Salesforce/blip2-flan-t5-xl

# ------------------------------------------------------------
# FastAPI Server
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
